# =============================================================================
# .env.example — Docker Compose Environment Reference
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in your real values before running:
#   cp .env.example .env
#
# This file is read by docker-compose.yml via `env_file: .env`.
# NEVER commit your real .env to version control.
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================

# Runtime environment: LOCAL | STAGING | PRODUCTION
ENVIRONMENT=LOCAL


# =============================================================================
# FRONTEND (Vite build-time variables)
# =============================================================================

# Backend API base URL seen by the browser.
# Leave empty when running through Docker (nginx proxies /api → backend).
# Set to http://localhost:8000 for local non-Docker development.
VITE_API_URL=

# Google OAuth client ID (same value used by both frontend and backend).
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# VAPID public key for Web Push notifications (optional).
VITE_VAPID_PUBLIC_KEY=


# =============================================================================
# POSTGRESQL
# =============================================================================

# Docker service name — keep as "postgres" when running via Docker Compose.
# Change to "localhost" for local non-Docker backend development.
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=productivity_db


# =============================================================================
# JWT
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET_KEY=change_me_to_another_random_64_char_hex_string


# =============================================================================
# REDIS
# =============================================================================

# Docker service name — keep as "redis" when running via Docker Compose.
# Change to "localhost" for local non-Docker backend development.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CELERY_BROKER_URL=redis://redis:6379/0


# =============================================================================
# SMTP
# =============================================================================

# --- LOCAL (Mailpit) ----------------------------------------------------------
# Mailpit runs only with the "local" profile.
# Start with: docker compose --profile local up -d
# View caught emails at http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=False
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@saasproductivity.local

# --- PRODUCTION (Brevo / SendinBlue) ------------------------------------------
# Fill these in for production. Mailpit is not started in production.
BREVO_API_KEY=
BREVO_FROM_EMAIL=


# =============================================================================
# GOOGLE OAUTH
# =============================================================================

# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback


# =============================================================================
# FILE STORAGE
# =============================================================================

# --- LOCAL -------------------------------------------------------------------
# Relative path inside the container where uploads are stored.
STORAGE_BASE_DIR=downloads

# --- PRODUCTION (AWS S3) -----------------------------------------------------
# Leave blank for local storage. Fill in to switch to S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_STORAGE_BUCKET_NAME=


# =============================================================================
# MEETINGS
# =============================================================================

# How long a meeting session JWT token stays valid (minutes).
MEETING_SESSION_TOKEN_EXPIRE_MINUTES=60


# =============================================================================
# FRONTEND URL
# =============================================================================

# Used by the backend to build links inside notification/reminder emails.
# Docker (nginx on port 80):  http://localhost
# Local non-Docker dev:       http://localhost:5173
FRONTEND_URL=http://localhost


# =============================================================================
# AI — NVIDIA NIM
# =============================================================================

# Used for meeting transcript analysis.
# Get a key at https://build.nvidia.com
NVIDIA_NIM_API_KEY=


# =============================================================================
# VAPID — Web Push Notifications (optional)
# =============================================================================

# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
