# =============================================================================
# .dockerignore — excludes files from ALL Docker build contexts
# =============================================================================

# Version control
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.venv
venv

# Node
node_modules

# IDE
.vscode
.idea
*.swp
*.swo

# Environment (secrets injected at runtime)
.env
.env.*
example.env

# Tests
tests
.pytest_cache
.coverage
coverage.xml

# Logs & uploads (ephemeral)
logs/
downloads/

# Build artifacts
dist/
build/

# Docker
docker-compose.yml
Dockerfile
.dockerignore

# Documentation
*.md
LICENSE

# OS
.DS_Store
Thumbs.db
